# Copy this file to `keystore.properties` (which is gitignored) and fill in your
# real release-signing values. Used by app/build.gradle.kts to sign release builds.
#
# storeFile: path to your keystore. Absolute, or relative to the app/ module dir.
# Keep the actual .jks OUTSIDE the repo and back it up — losing it means you
# cannot ship Play Store updates.

storeFile=/Users/you/keystores/orthodox-calendar.jks
storePassword=your-keystore-password
keyAlias=orthodox-upload
keyPassword=your-key-password
